@page "/profile"
@inject AppState AppState
@inject IAuthApi AuthApi
@inject IEmployeeApi EmployeeApi
@inject ISecureStorageService SecureStorage
@inject NavigationManager Navigation
@inject ISnackbar Snackbar
@inject IDialogService DialogService

<div class="profile-container">
    @* Profile Header *@
    <div class="profile-header">
        <MudAvatar Size="Size.Large" Color="Color.Primary" Class="profile-avatar">
            @if (!string.IsNullOrEmpty(AppState.Employee?.ImageUrl))
            {
                <MudImage Src="@AppState.Employee.ImageUrl" Alt="Profile" />
            }
            else
            {
                @AppState.Employee?.Initials
            }
        </MudAvatar>
        <MudText Typo="Typo.h5" Class="font-bold">@AppState.Employee?.Name</MudText>
        <MudText Typo="Typo.body2" Color="Color.Secondary">@FormatCpf(AppState.Employee?.Cpf ?? "")</MudText>
    </div>

    @* Settings Sections *@
    <MudCard Class="settings-card">
        <MudCardContent>
            <MudText Typo="Typo.overline" Color="Color.Secondary">SEGURANÇA</MudText>

            <MudList T="string" Dense="true">
                <MudListItem Icon="@Icons.Material.Filled.Pin" OnClick="ChangePin">
                    <MudText>Alterar PIN</MudText>
                </MudListItem>
                <MudListItem Icon="@Icons.Material.Filled.Fingerprint" OnClick="HandleBiometricAction">
                    <div class="list-item-content">
                        <div>
                            <MudText>Biometria</MudText>
                            <MudText Typo="Typo.caption" Color="@(_hasBiometric ? Color.Success : Color.Secondary)">
                                @(_hasBiometric ? "Configurada ?" : "Năo configurada")
                            </MudText>
                        </div>
                        <MudIcon Icon="@Icons.Material.Filled.ChevronRight" Size="Size.Small" Color="Color.Secondary" />
                    </div>
                </MudListItem>
                <MudListItem Icon="@Icons.Material.Filled.Password" OnClick="ChangePassword">
                    <MudText>Alterar Senha</MudText>
                </MudListItem>
            </MudList>
        </MudCardContent>
    </MudCard>

    <MudCard Class="settings-card">
        <MudCardContent>
            <MudText Typo="Typo.overline" Color="Color.Secondary">PREFERĘNCIAS</MudText>

            <MudList T="string" Dense="true">
                <MudListItem Icon="@(AppState.IsDarkMode ? Icons.Material.Filled.DarkMode : Icons.Material.Filled.LightMode)">
                    <div class="list-item-content">
                        <MudText>Modo Escuro</MudText>
                        <MudSwitch T="bool" Value="AppState.IsDarkMode" ValueChanged="ToggleDarkMode" Color="Color.Primary" />
                    </div>
                </MudListItem>
                <MudListItem Icon="@Icons.Material.Filled.Notifications">
                    <div class="list-item-content">
                        <MudText>Notificaçőes</MudText>
                        <MudSwitch T="bool" @bind-Value="_notificationsEnabled" Color="Color.Primary" />
                    </div>
                </MudListItem>
            </MudList>
        </MudCardContent>
    </MudCard>

    @if (AppState.IsOwner)
    {
        <MudCard Class="settings-card">
            <MudCardContent>
                <MudText Typo="Typo.overline" Color="Color.Secondary">GERENCIAR BIOMETRIA DOS FUNCIONÁRIOS</MudText>

                @if (_isLoadingEmployees)
                {
                    <div style="display: flex; justify-content: center; padding: 24px;">
                        <MudProgressCircular Indeterminate="true" Size="Size.Medium" />
                    </div>
                }
                else if (!_employees.Any())
                {
                    <div style="text-align: center; padding: 16px;">
                        <MudIcon Icon="@Icons.Material.Filled.GroupOff" Size="Size.Large" Color="Color.Secondary" />
                        <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mt-2">Nenhum funcionário ativo</MudText>
                    </div>
                }
                else
                {
                    <MudList T="EmployeeSummaryItem" Dense="true">
                        @foreach (var emp in _employees)
                        {
                            <MudListItem OnClick="@(() => SetupEmployeeBiometric(emp))">
                                <div style="display: flex; align-items: center; gap: 12px; width: 100%;">
                                    <MudAvatar Size="Size.Small" Color="Color.Primary">
                                        @GetInitials(emp.Name)
                                    </MudAvatar>
                                    <div style="flex: 1;">
                                        <MudText Typo="Typo.body2" Class="font-semibold">@emp.Name</MudText>
                                    </div>
                                    <MudIcon Icon="@Icons.Material.Filled.Fingerprint" Size="Size.Small"
                                             Color="@(emp.HasFingerprint ? Color.Success : Color.Default)" />
                                    <MudText Typo="Typo.caption" Color="@(emp.HasFingerprint ? Color.Success : Color.Secondary)">
                                        @(emp.HasFingerprint ? "?" : "—")
                                    </MudText>
                                </div>
                            </MudListItem>
                        }
                    </MudList>
                }
            </MudCardContent>
        </MudCard>
    }

    <MudCard Class="settings-card">
        <MudCardContent>
            <MudText Typo="Typo.overline" Color="Color.Secondary">SOBRE</MudText>

            <MudList T="string" Dense="true">
                <MudListItem Icon="@Icons.Material.Filled.Info">
                    <div class="list-item-content">
                        <MudText>Versăo</MudText>
                        <MudText Typo="Typo.body2" Color="Color.Secondary">1.0.0</MudText>
                    </div>
                </MudListItem>
                <MudListItem Icon="@Icons.Material.Filled.Description" OnClick="OpenTerms">
                    <MudText>Termos de Uso</MudText>
                </MudListItem>
                <MudListItem Icon="@Icons.Material.Filled.PrivacyTip" OnClick="OpenPrivacy">
                    <MudText>Política de Privacidade</MudText>
                </MudListItem>
                <MudListItem Icon="@Icons.Material.Filled.Help" OnClick="OpenSupport">
                    <MudText>Suporte</MudText>
                </MudListItem>
            </MudList>
        </MudCardContent>
    </MudCard>

    @* Logout Button *@
    <MudButton Variant="Variant.Outlined"
               Color="Color.Error"
               FullWidth="true"
               StartIcon="@Icons.Material.Filled.Logout"
               Class="logout-button"
               OnClick="Logout">
        Sair da Conta
    </MudButton>

    <div class="footer-info">
        <MudText Typo="Typo.caption" Color="Color.Secondary">
            © 2025 DottIn - Todos os direitos reservados
        </MudText>
    </div>
</div>

<style>
    .profile-container {
        padding: 24px 20px;
        display: flex;
        flex-direction: column;
        gap: 16px;
    }

    .profile-header {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 12px;
        padding: 24px 0;
    }

    .profile-avatar {
        width: 96px !important;
        height: 96px !important;
        font-size: 32px !important;
    }

    .settings-card {
        border-radius: 16px !important;
    }

    .list-item-content {
        display: flex;
        justify-content: space-between;
        align-items: center;
        width: 100%;
    }

    .logout-button {
        margin-top: 8px;
        border-radius: 12px !important;
    }

    .footer-info {
        text-align: center;
        padding: 24px 0;
    }
</style>

@code {
    private bool _hasBiometric = false;
    private bool _notificationsEnabled = true;
    private bool _isLoadingEmployees = false;
    private List<EmployeeSummaryItem> _employees = [];

    protected override async Task OnInitializedAsync()
    {
        var token = await SecureStorage.GetAsync("fingerprint_token");
        _hasBiometric = !string.IsNullOrEmpty(token);

        var notifications = await SecureStorage.GetAsync("notifications_enabled");
        _notificationsEnabled = notifications != "false";

        if (AppState.IsOwner)
            await LoadEmployees();
    }

    private async Task ToggleDarkMode(bool value)
    {
        AppState.SetDarkMode(value);
        await SecureStorage.SetAsync("dark_mode", value.ToString().ToLower());
    }

    private async Task LoadEmployees()
    {
        _isLoadingEmployees = true;
        try
        {
            var employees = await EmployeeApi.GetActiveByBranchAsync(AppState.BranchId);
            _employees = employees
                .Where(e => e.EmployeeId != AppState.EmployeeId)
                .ToList();
        }
        catch
        {
            _employees = [];
        }
        finally
        {
            _isLoadingEmployees = false;
        }
    }

    private async Task SetupEmployeeBiometric(EmployeeSummaryItem employee)
    {
        var companyCode = await SecureStorage.GetAsync("company_code") ?? "";

        var parameters = new DialogParameters<BiometricSetupDialog>
        {
            { x => x.CompanyCode, companyCode },
            { x => x.Cpf, employee.Document.Value },
            { x => x.EmployeeId, employee.EmployeeId },
            { x => x.EmployeeName, employee.Name }
        };

        var options = new DialogOptions
        {
            MaxWidth = MaxWidth.Small,
            FullWidth = true,
            CloseOnEscapeKey = true
        };

        var dialog = await DialogService.ShowAsync<BiometricSetupDialog>($"Biometria - {employee.Name}", parameters, options);
        var result = await dialog.Result;

        if (result is not null && !result.Canceled)
        {
            await LoadEmployees();
            Snackbar.Add($"Biometria configurada para {employee.Name}!", Severity.Success);
        }
    }

    private string GetInitials(string name) =>
        string.Join("", name.Split(' ').Take(2).Select(n => n.FirstOrDefault()));

    private async Task ChangePin()
    {
        var parameters = new DialogParameters<ChangePinDialog>
        {
            { x => x.CompanyCode, await SecureStorage.GetAsync("company_code") ?? "" },
            { x => x.Cpf, AppState.Employee?.Cpf ?? "" }
        };

        var options = new DialogOptions
        {
            MaxWidth = MaxWidth.Small,
            FullWidth = true,
            CloseOnEscapeKey = true
        };

        var dialog = await DialogService.ShowAsync<ChangePinDialog>("Alterar PIN", parameters, options);
        var result = await dialog.Result;

        if (result is not null && !result.Canceled)
        {
            Snackbar.Add("PIN alterado com sucesso!", Severity.Success);
        }
    }

    private async Task HandleBiometricAction()
    {
        if (_hasBiometric)
        {
            var result = await DialogService.ShowMessageBox(
                "Biometria",
                "O que deseja fazer com a biometria?",
                yesText: "Reconfigurar",
                noText: "Remover",
                cancelText: "Cancelar");

            if (result == true)
            {
                await SetupBiometric();
            }
            else if (result == false)
            {
                await RemoveBiometric();
            }
        }
        else
        {
            await SetupBiometric();
        }
    }

    private async Task SetupBiometric()
    {
        var parameters = new DialogParameters<BiometricSetupDialog>
        {
            { x => x.CompanyCode, await SecureStorage.GetAsync("company_code") ?? "" },
            { x => x.Cpf, AppState.Employee?.Cpf ?? "" }
        };

        var options = new DialogOptions
        {
            MaxWidth = MaxWidth.Small,
            FullWidth = true,
            CloseOnEscapeKey = true
        };

        var dialog = await DialogService.ShowAsync<BiometricSetupDialog>("Configurar Biometria", parameters, options);
        var result = await dialog.Result;

        if (result is not null && !result.Canceled)
        {
            _hasBiometric = true;
            Snackbar.Add("Biometria configurada com sucesso!", Severity.Success);
        }
    }

    private async Task RemoveBiometric()
    {
        await SecureStorage.RemoveAsync("fingerprint_token");
        await SecureStorage.RemoveAsync("fingerprint_cpf");
        await SecureStorage.RemoveAsync("fingerprint_company");
        _hasBiometric = false;
        Snackbar.Add("Biometria removida", Severity.Info);
    }

    private async Task ChangePassword()
    {
        var parameters = new DialogParameters<ChangePasswordDialog>
        {
            { x => x.CompanyCode, await SecureStorage.GetAsync("company_code") ?? "" },
            { x => x.Cpf, AppState.Employee?.Cpf ?? "" }
        };

        var options = new DialogOptions
        {
            MaxWidth = MaxWidth.Small,
            FullWidth = true,
            CloseOnEscapeKey = true
        };

        var dialog = await DialogService.ShowAsync<ChangePasswordDialog>("Alterar Senha", parameters, options);
        var result = await dialog.Result;

        if (result is not null && !result.Canceled)
        {
            Snackbar.Add("Senha alterada com sucesso!", Severity.Success);
        }
    }

    private void OpenTerms()
    {
        // TODO: Open terms URL
    }

    private void OpenPrivacy()
    {
        // TODO: Open privacy URL
    }

    private void OpenSupport()
    {
        // TODO: Open support URL or email
    }

    private async Task Logout()
    {
        var result = await DialogService.ShowMessageBox(
            "Sair",
            "Tem certeza que deseja sair da sua conta?",
            yesText: "Sair",
            cancelText: "Cancelar");

        if (result == true)
        {
            try { await AuthApi.LogoutAsync(); } catch { }
            await SecureStorage.ClearAllAsync();
            AppState.Logout();
            Navigation.NavigateTo("/login", true);
        }
    }

    private string FormatCpf(string cpf)
    {
        if (cpf.Length != 11) return cpf;
        return $"{cpf.Substring(0, 3)}.{cpf.Substring(3, 3)}.{cpf.Substring(6, 3)}-{cpf.Substring(9, 2)}";
    }
}
