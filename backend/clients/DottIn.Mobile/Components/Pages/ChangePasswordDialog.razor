@using MudBlazor
@using DottIn.Mobile.Services
@using DottIn.Mobile.Services.Interfaces

<MudDialog>
    <TitleContent>
        <div style="display: flex; align-items: center; gap: 8px;">
            <MudIcon Icon="@Icons.Material.Filled.Password" />
            <MudText Typo="Typo.h6">Alterar Senha</MudText>
        </div>
    </TitleContent>
    <DialogContent>
        <MudTextField @bind-Value="_currentPassword"
                      Label="Senha Atual"
                      Placeholder="Digite sua senha atual"
                      Variant="Variant.Outlined"
                      Adornment="Adornment.Start"
                      AdornmentIcon="@Icons.Material.Filled.Lock"
                      InputType="InputType.Password"
                      FullWidth="true"
                      Class="mb-3"
                      Disabled="@_isProcessing" />

        <MudTextField @bind-Value="_newPassword"
                      Label="Nova Senha"
                      Placeholder="Mínimo 6 caracteres"
                      Variant="Variant.Outlined"
                      Adornment="Adornment.Start"
                      AdornmentIcon="@Icons.Material.Filled.LockReset"
                      InputType="InputType.Password"
                      FullWidth="true"
                      Class="mb-3"
                      Disabled="@_isProcessing" />

        <MudTextField @bind-Value="_confirmPassword"
                      Label="Confirmar Nova Senha"
                      Placeholder="Repita a nova senha"
                      Variant="Variant.Outlined"
                      Adornment="Adornment.Start"
                      AdornmentIcon="@Icons.Material.Filled.LockReset"
                      InputType="InputType.Password"
                      FullWidth="true"
                      Disabled="@_isProcessing"
                      Error="@(_confirmPassword.Length > 0 && _newPassword != _confirmPassword)"
                      ErrorText="As senhas não coincidem" />

        @if (!string.IsNullOrEmpty(_errorMessage))
        {
            <MudAlert Severity="Severity.Error" Dense="true" Class="mt-3">@_errorMessage</MudAlert>
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel" Variant="Variant.Text" Disabled="@_isProcessing">Cancelar</MudButton>
        <MudButton OnClick="Submit" Variant="Variant.Filled" Color="Color.Primary"
                   Disabled="@(!IsFormValid() || _isProcessing)">
            @if (_isProcessing)
            {
                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
            }
            Alterar
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; } = default!;

    [Parameter] public string CompanyCode { get; set; } = "";
    [Parameter] public string Cpf { get; set; } = "";

    [Inject] private IAuthApi AuthApi { get; set; } = default!;

    private string _currentPassword = "";
    private string _newPassword = "";
    private string _confirmPassword = "";
    private bool _isProcessing = false;
    private string _errorMessage = "";

    private bool IsFormValid() =>
        !string.IsNullOrWhiteSpace(_currentPassword) &&
        !string.IsNullOrWhiteSpace(_newPassword) &&
        _newPassword.Length >= 6 &&
        _newPassword == _confirmPassword;

    private async Task Submit()
    {
        _isProcessing = true;
        _errorMessage = "";

        try
        {
            var request = new ChangePasswordRequest(CompanyCode, Cpf, _currentPassword, _newPassword);
            await AuthApi.ChangePasswordAsync(request);
            MudDialog.Close(DialogResult.Ok(true));
        }
        catch (Refit.ApiException apiEx) when (apiEx.StatusCode == System.Net.HttpStatusCode.Unauthorized)
        {
            _errorMessage = "Senha atual incorreta";
        }
        catch (Refit.ApiException apiEx) when (apiEx.StatusCode == System.Net.HttpStatusCode.BadRequest)
        {
            _errorMessage = "A nova senha deve ser diferente da atual e ter no mínimo 6 caracteres";
        }
        catch (Exception)
        {
            _errorMessage = "Erro ao alterar senha. Tente novamente.";
        }
        finally
        {
            _isProcessing = false;
        }
    }

    private void Cancel() => MudDialog.Cancel();
}
